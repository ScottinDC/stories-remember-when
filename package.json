{
  "name": "remember-when",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --host 127.0.0.1",
    "server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "build:netlify": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node dist-server/index.js",
    "dev:local": "bash scripts/dev-local.sh"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.16.0",
    "@netlify/functions": "^5.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^6.0.11",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "openai": "^4.77.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/d3": "^7.4.3",
    "@types/d3-sankey": "^0.12.5",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1"
  }
}

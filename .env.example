OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_STORAGE_BUCKET=
# Either point to a service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
# Or paste service account JSON into one env var for hosted deployments:
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON=

DATABASE_PATH=./data/remember-when.sqlite
PORT=8787
